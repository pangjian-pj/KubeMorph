{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug server",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "cwd": "${workspaceFolder}/server",
      "program": "${workspaceFolder}/server/cmd/server",
      "env": {
        "KUBEX_SERVER_ADDR": ":8080",
        "KUBEX_LOG_LEVEL": "debug",
        "KUBEX_ETCD_ENDPOINTS": "http://localhost:2379",
        "KUBEX_KUBERNETES_KUBECONFIG": "/Users/pangjian/researchProjects/kubeX/.kubeconfig-server",
        "KUBEX_KUBERNETES_NAMESPACE": "kubex-system"
      }
    },
    {
      "name": "Debug controller",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "cwd": "${workspaceFolder}/controller",
      "program": "${workspaceFolder}/controller/cmd/main.go",
      "buildFlags": "-tags=kubex_ortools",
      "args": [
        "--leader-elect=false",
        "--metrics-bind-address=0",
        "--health-probe-bind-address=:8082"
      ],
      "env": {
        "KUBECONFIG": "/Users/pangjian/researchProjects/kubeX/.kubeconfig-server"
      }
    }
  ]
}
